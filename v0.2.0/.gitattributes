# =============================================================================
# .gitattributes — Нормализация line-endings и поведения git с разными типами
# =============================================================================
# Защита от того что друг на Windows склонирует репо и получит CRLF в .sh.
# =============================================================================

# По умолчанию — авто-определение, line-endings в репо всегда LF
*               text=auto eol=lf

# Текстовые форматы которые ОБЯЗАНЫ быть LF (иначе сломается NixOS)
*.nix           text eol=lf
*.sh            text eol=lf
*.bash          text eol=lf
*.fish          text eol=lf
*.conf          text eol=lf
*.toml          text eol=lf
*.json          text eol=lf
*.jsonc         text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.md            text eol=lf

# Бинарники
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.webp          binary
*.ico           binary
*.pdf           binary
*.zip           binary
*.tar.gz        binary
