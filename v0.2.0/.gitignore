# =============================================================================
# .gitignore — Локальные файлы конкретной машины не попадают в git
# =============================================================================
# Файлы перечисленные ниже физически существуют на диске и читаются Nix'ом
# (через `nixos-install --flake "path:.#<host>"` и `nrs`), но git их не
# отслеживает: они не входят в коммиты и не уходят при `git push`.
#
# Это позволяет:
#   - получать обновления через `git pull upstream main` без конфликтов с локальным
#   - пушить свой fork в публичный github без раскрытия hostname/UUID/настроек
#   - друзьям клонировать репо и получать чистую базу без личных вещей
# =============================================================================

# ── Заполненные хосты — личное (hostname, диск, gitEmail и т.д.) ───────────
# Шаблон в hosts/_template/ остаётся в репо.
hosts/*/settings.nix
hosts/*/hardware.nix
!hosts/_template/settings.nix
!hosts/_template/hardware.nix

# ── Кастомные оверрайды конкретной машины ──────────────────────────────────
# Файл custom/<host>.nix или папка custom/<host>/.
# Пример и README остаются в репо.
custom/*.nix
custom/*/
!custom/_example.nix
!custom/README.md

# ── flake.lock — твой выбор ───────────────────────────────────────────────
# Закомментируй строку ниже если хочешь чтобы flake.lock тоже не уходил в
# твой публичный fork. По умолчанию lock коммитится — это нужно для
# воспроизводимости.
# flake.lock

# ── Стандартные исключения ─────────────────────────────────────────────────
*.bak
*.swp
*.swo
.direnv/
result
result-*
