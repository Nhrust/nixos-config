# =============================================================================
# .editorconfig — Единые настройки отступов и переносов строк
# =============================================================================
# Поддерживается всеми основными редакторами (VS Code, JetBrains, vim, emacs,
# nano с плагином, и т.д.). Гарантирует что у всех contributor'ов код
# отформатирован одинаково.
# =============================================================================
root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 2

[*.nix]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false  # двойной пробел = <br> в Markdown
indent_size              = 2

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2

[*.{json,jsonc,toml,yaml,yml}]
indent_size = 2
