# =============================================================================
# modules/user/tools.nix — Консольные утилиты
# =============================================================================
{ pkgs, ... }:
{
  home.packages = with pkgs; [
    # ── Навигация ─────────────────────────────────────────────────────────
    eza         # ls с иконками, цветами, git-интеграцией
    yazi        # файловый менеджер TUI с превью
    fd          # find быстрее, человеческий синтаксис

    # ── Просмотр и поиск ──────────────────────────────────────────────────
    bat         # cat с подсветкой синтаксиса
    ripgrep     # grep в разы быстрее (rg)
    fzf         # fuzzy-поиск в консоли

    # ── Мониторинг ────────────────────────────────────────────────────────
    btop        # CPU/RAM/диски/сеть/процессы
    duf         # df с читаемым выводом
    dust        # дерево папок по размеру

    # ── Сеть ──────────────────────────────────────────────────────────────
    nmap

    # ── Редактор ──────────────────────────────────────────────────────────
    helix       # modal редактор с LSP из коробки

    # ── Информация о системе ──────────────────────────────────────────────
    fastfetch
  ];
}
