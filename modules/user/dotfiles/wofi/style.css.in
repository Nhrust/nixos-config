/* wofi style — theme-aware (v0.4.0+), генерируется из style.css.in
 * Цвета подставляются substituteAll из lib/catppuccin-colors.nix
 * по settings.theme (mocha/latte) и settings.themeAccent.
 */

window {
    margin: 0;
    background-color: rgba(@base_rgb@, 0.95);
    border-radius: 12px;
    border: 2px solid #@accent@;
    font-family: "JetBrainsMono Nerd Font";
    font-size: 14px;
}

#input {
    margin: 8px;
    padding: 8px 12px;
    border: none;
    background-color: #@surface0@;
    color: #@text@;
    border-radius: 8px;
}

#inner-box {
    margin: 8px;
}

#outer-box {
    margin: 0;
}

#text {
    color: #@text@;
}

#entry:selected {
    background-color: #@surface1@;
    border-radius: 6px;
}

#entry:selected #text {
    color: #@accent@;
}
