# hyprlock.conf — Lock screen, theme-aware (v0.4.0+)
# Генерируется из hyprlock.conf.in через pkgs.substituteAll
# по settings.theme и settings.themeAccent.

background {
    monitor =
    path    = ~/Pictures/wallpaper.png
    blur_passes = 3
    blur_size   = 8
}

input-field {
    monitor       =
    size          = 250, 50
    outline_thickness = 2
    dots_size     = 0.2
    dots_spacing  = 0.3
    inner_color   = rgb(@base_rgb@)
    outer_color   = rgb(@accent_rgb@)
    font_color    = rgb(@text_rgb@)
    placeholder_text = <i>Введите пароль...</i>
    position      = 0, -100
    halign        = center
    valign        = center
}

label {
    monitor =
    text    = cmd[update:1000] echo "$(date +"%H:%M")"
    font_size = 64
    color     = rgb(@text_rgb@)
    position  = 0, 100
    halign    = center
    valign    = center
}
