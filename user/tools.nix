{ pkgs, ... }:
{
  home.packages = with pkgs; [
    # ── Навигация ─────────────────────────────────────────────────────────────
    eza      # ls с цветами, иконками и git-интеграцией
    zoxide   # умный cd: запоминает частые папки, команда z
    yazi     # файловый менеджер TUI с превью
    fd       # find быстрее и с человеческим синтаксисом

    # ── Просмотр и поиск ─────────────────────────────────────────────────────
    bat      # cat с подсветкой синтаксиса (включая .nix файлы)
    ripgrep  # grep в разы быстрее, команда rg
    fzf      # интерактивный fuzzy-поиск в консоли

    # ── Мониторинг системы ────────────────────────────────────────────────────
    btop     # CPU / RAM / диски / сеть / процессы в одном окне
    duf      # df с читаемым выводом, видны Btrfs сабволюмы
    dust     # du в виде дерева папок по размеру

    # ── Сеть ─────────────────────────────────────────────────────────────────
    nmap     # сканирование сети и диагностика портов

    # ── Редактор ─────────────────────────────────────────────────────────────
    helix    # modal редактор, подсветка Nix из коробки, встроенный LSP

    # ── Системная информация ──────────────────────────────────────────────────
    fastfetch # информация о системе при входе в консоль
  ];
}
