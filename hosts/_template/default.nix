# =============================================================================
# hosts/<host>/default.nix — Entry-point модулей кастомизации этой машины
# =============================================================================
# Этот файл подключается из lib/mkHost.nix вместе с settings.nix и
# hardware.nix. Импорт ниже — список всех твоих модулей кастомизации;
# закомментируй те которые тебе не нужны.
#
# Все эти .nix файлы лежат рядом в hosts/<host>/ и редактируются
# индивидуально — каждый отвечает за свою тему.
# =============================================================================
{ ... }: {
  imports = [
    ./packages.nix             # Дополнительные системные/пользовательские пакеты
    ./services.nix             # Системные сервисы (tailscale, syncthing, etc)
    ./aliases.nix              # Декларативные fish-алиасы
    # ./extras-gaming.nix      # Подключить extras/gaming.nix + настройка
    # ./extras-development.nix # Подключить extras/development.nix + настройка
    # ./overrides.nix          # Override опций из modules/ через lib.mkForce
    # ./secrets-usage.nix      # Использование секретов из sops
  ];
}
